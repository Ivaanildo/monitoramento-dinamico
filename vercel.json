{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "rootDirectory": "frontend",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/auth/:path*",
      "destination": "https://monitoramento-dinamico-production.up.railway.app/auth/:path*"
    },
    {
      "source": "/painel",
      "destination": "https://monitoramento-dinamico-production.up.railway.app/painel"
    },
    {
      "source": "/painel/:path*",
      "destination": "https://monitoramento-dinamico-production.up.railway.app/painel/:path*"
    },
    {
      "source": "/rotas/:path*",
      "destination": "https://monitoramento-dinamico-production.up.railway.app/rotas/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
